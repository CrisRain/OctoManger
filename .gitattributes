# 所有文本文件在仓库中统一存储为 LF
* text=auto eol=lf

# Shell 脚本强制 LF，无论在哪个平台签出
*.sh text eol=lf

# Python / Go 源文件同样使用 LF
*.py text eol=lf
*.go text eol=lf

# 配置与文档
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.toml text eol=lf

# Web 前端
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Windows 专属文件保留 CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# 二进制文件不做行尾处理
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
