{
  "key": "octo_demo",
  "name": "OctoDemo 演示",
  "category": "generic",
  "schema": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "title": "用户名",
        "description": "内置演示服务中的用户名"
      },
      "api_key": {
        "type": "string",
        "title": "API Key",
        "description": "内置演示服务返回的 API 密钥"
      },
      "base_url": {
        "type": "string",
        "title": "服务地址",
        "description": "内置演示服务监听地址，例如 http://127.0.0.1:18080",
        "default": "http://127.0.0.1:18080"
      }
    },
    "required": [
      "username",
      "api_key"
    ]
  },
  "capabilities": {
    "actions": [
      {
        "key": "VERIFY",
        "description": "验证账号凭证是否有效"
      },
      {
        "key": "GET_PROFILE",
        "description": "获取用户资料，并将关键字段写回账号 spec"
      },
      {
        "key": "LIST_TASKS",
        "description": "分页查询账号下的任务",
        "params": [
          {
            "name": "status",
            "type": "string",
            "label": "任务状态",
            "required": false,
            "description": "状态过滤",
            "placeholder": "",
            "account_type_key": "",
            "bind": ""
          },
          {
            "name": "priority",
            "type": "string",
            "label": "优先级",
            "required": false,
            "description": "优先级过滤",
            "placeholder": "",
            "account_type_key": "",
            "bind": ""
          },
          {
            "name": "page",
            "type": "integer",
            "label": "页码",
            "default": 1,
            "required": false,
            "description": "页码",
            "placeholder": "",
            "min": 1,
            "account_type_key": "",
            "bind": ""
          },
          {
            "name": "page_size",
            "type": "integer",
            "label": "每页条数",
            "default": 20,
            "required": false,
            "description": "每页条数",
            "placeholder": "",
            "min": 1,
            "max": 50,
            "account_type_key": "",
            "bind": ""
          }
        ]
      },
      {
        "key": "CREATE_TASK",
        "description": "创建新任务（mode=job，写入后台日志）",
        "params": [
          {
            "name": "title",
            "type": "string",
            "label": "任务标题",
            "required": true,
            "description": "任务标题",
            "placeholder": "",
            "account_type_key": "",
            "bind": ""
          },
          {
            "name": "priority",
            "type": "string",
            "label": "优先级",
            "default": "medium",
            "required": false,
            "choices": [
              "low",
              "medium",
              "high",
              "critical"
            ],
            "description": "优先级",
            "placeholder": "",
            "account_type_key": "",
            "bind": ""
          }
        ]
      },
      {
        "key": "COMPLETE_TASK",
        "description": "将指定任务标记为已完成",
        "params": [
          {
            "name": "task_id",
            "type": "string",
            "label": "任务 ID",
            "required": true,
            "description": "任务 ID",
            "placeholder": "",
            "account_type_key": "",
            "bind": ""
          }
        ]
      },
      {
        "key": "DELETE_TASK",
        "description": "删除指定任务",
        "params": [
          {
            "name": "task_id",
            "type": "string",
            "label": "任务 ID",
            "required": true,
            "description": "任务 ID",
            "placeholder": "",
            "account_type_key": "",
            "bind": ""
          }
        ]
      },
      {
        "key": "REGISTER",
        "description": "自动注册新账号并填充凭证（仅在创建账号时使用）",
        "params": [
          {
            "name": "display_name",
            "type": "string",
            "label": "显示名称",
            "required": false,
            "description": "显示名称",
            "placeholder": "",
            "account_type_key": "",
            "bind": ""
          }
        ]
      },
      {
        "key": "AGENT_FAKE_SERVER",
        "description": "Agent 模式：启动并保活插件内置演示服务"
      },
      {
        "key": "AGENT_MONITOR",
        "description": "Agent 模式：定期采集任务统计并上报异常"
      }
    ]
  },
  "settings": [
    {
      "key": "default_page_size",
      "label": "默认分页大小",
      "type": "string",
      "secret": false,
      "default": "20",
      "description": "列表查询时每页返回的条目数 (1–50)",
      "required": false
    },
    {
      "key": "debug_mode",
      "label": "调试模式",
      "type": "string",
      "secret": false,
      "default": "false",
      "description": "设为 true 时输出更详细的日志",
      "required": false
    },
    {
      "key": "agent_loop_hint",
      "label": "Agent 循环提示 (秒)",
      "type": "string",
      "secret": false,
      "default": "60",
      "description": "用于估算内置演示服务租约；实际循环间隔仍由 Worker 的 WORKER_AGENT_LOOP_INTERVAL 控制",
      "required": false
    }
  ],
  "ui": {
    "tabs": [
      {
        "key": "overview",
        "label": "概览",
        "sections": [
          {
            "title": "账号操作",
            "fields": [],
            "buttons": [
              {
                "action": "VERIFY",
                "label": "验证账号",
                "variant": "outline",
                "mode": "sync",
                "params": {},
                "form": []
              },
              {
                "action": "GET_PROFILE",
                "label": "获取并同步资料",
                "variant": "outline",
                "mode": "sync",
                "params": {},
                "form": []
              }
            ]
          }
        ],
        "context": ""
      },
      {
        "key": "tasks",
        "label": "任务",
        "sections": [
          {
            "title": "查询任务",
            "fields": [],
            "buttons": [
              {
                "action": "LIST_TASKS",
                "label": "查询任务列表",
                "variant": "outline",
                "mode": "sync",
                "params": {},
                "form": [
                  {
                    "name": "status",
                    "type": "string",
                    "label": "任务状态",
                    "required": false,
                    "choices": [
                      "",
                      "pending",
                      "in_progress",
                      "completed",
                      "cancelled"
                    ],
                    "description": "按状态过滤（留空=全部）",
                    "placeholder": "",
                    "account_type_key": "",
                    "bind": ""
                  },
                  {
                    "name": "priority",
                    "type": "string",
                    "label": "优先级",
                    "required": false,
                    "choices": [
                      "",
                      "low",
                      "medium",
                      "high",
                      "critical"
                    ],
                    "description": "按优先级过滤（留空=全部）",
                    "placeholder": "",
                    "account_type_key": "",
                    "bind": ""
                  },
                  {
                    "name": "page",
                    "type": "integer",
                    "label": "页码",
                    "default": 1,
                    "required": false,
                    "description": "页码",
                    "placeholder": "",
                    "min": 1,
                    "account_type_key": "",
                    "bind": ""
                  }
                ]
              }
            ]
          },
          {
            "title": "新建任务",
            "fields": [],
            "buttons": [
              {
                "action": "CREATE_TASK",
                "label": "创建任务",
                "variant": "outline",
                "mode": "job",
                "params": {},
                "form": [
                  {
                    "name": "title",
                    "type": "string",
                    "label": "任务标题",
                    "required": true,
                    "description": "任务标题",
                    "placeholder": "例如：跟进客户消息",
                    "account_type_key": "",
                    "bind": ""
                  },
                  {
                    "name": "priority",
                    "type": "string",
                    "label": "优先级",
                    "default": "medium",
                    "required": false,
                    "choices": [
                      "low",
                      "medium",
                      "high",
                      "critical"
                    ],
                    "description": "优先级",
                    "placeholder": "",
                    "account_type_key": "",
                    "bind": ""
                  }
                ]
              }
            ]
          },
          {
            "title": "操作任务",
            "fields": [],
            "buttons": [
              {
                "action": "COMPLETE_TASK",
                "label": "标记为完成",
                "variant": "outline",
                "mode": "sync",
                "params": {},
                "form": [
                  {
                    "name": "task_id",
                    "type": "string",
                    "label": "任务 ID",
                    "required": true,
                    "description": "任务 ID（从查询结果中复制）",
                    "placeholder": "",
                    "account_type_key": "",
                    "bind": ""
                  }
                ]
              },
              {
                "action": "DELETE_TASK",
                "label": "删除任务",
                "variant": "outline",
                "mode": "sync",
                "params": {},
                "form": [
                  {
                    "name": "task_id",
                    "type": "string",
                    "label": "任务 ID",
                    "required": true,
                    "description": "任务 ID",
                    "placeholder": "",
                    "account_type_key": "",
                    "bind": ""
                  }
                ]
              }
            ]
          }
        ],
        "context": ""
      },
      {
        "key": "demo_server",
        "label": "演示服务",
        "sections": [
          {
            "title": "插件主进程内置服务",
            "fields": [],
            "buttons": [
              {
                "action": "AGENT_FAKE_SERVER",
                "label": "启动并保活演示服务",
                "variant": "outline",
                "mode": "agent",
                "params": {},
                "form": [
                  {
                    "name": "account",
                    "type": "account",
                    "label": "关联账号",
                    "required": false,
                    "description": "选填，选择后会把演示服务地址同步回该账号的 base_url",
                    "placeholder": "",
                    "account_type_key": "octo_demo",
                    "bind": ""
                  },
                  {
                    "name": "base_url",
                    "type": "string",
                    "label": "服务地址",
                    "default": "http://127.0.0.1:18080",
                    "required": false,
                    "description": "不填则使用默认地址，适合在插件详情页直接起一个本地演示服务",
                    "placeholder": "http://127.0.0.1:18081",
                    "account_type_key": "",
                    "bind": ""
                  },
                  {
                    "name": "lease_seconds",
                    "type": "integer",
                    "label": "保活时长（秒）",
                    "default": 180,
                    "required": false,
                    "description": "本轮 Agent 续租时长，过短会被自动提升到安全下限",
                    "placeholder": "",
                    "min": 120,
                    "max": 3600,
                    "account_type_key": "",
                    "bind": ""
                  }
                ]
              },
              {
                "action": "AGENT_MONITOR",
                "label": "创建任务监控 Agent",
                "variant": "outline",
                "mode": "agent",
                "params": {},
                "form": [
                  {
                    "name": "account",
                    "type": "account",
                    "label": "监控账号",
                    "required": true,
                    "description": "必填，选择要监控的 OctoDemo 账号",
                    "placeholder": "",
                    "account_type_key": "octo_demo",
                    "bind": ""
                  }
                ]
              }
            ]
          }
        ],
        "context": "plugin"
      },
      {
        "key": "register",
        "label": "注册",
        "sections": [
          {
            "title": "自动注册新账号",
            "fields": [],
            "buttons": [
              {
                "action": "REGISTER",
                "label": "自动注册",
                "variant": "outline",
                "mode": "sync",
                "params": {},
                "form": [
                  {
                    "name": "display_name",
                    "type": "string",
                    "label": "显示名称",
                    "required": false,
                    "description": "显示名称（可选，不填则使用用户名）",
                    "placeholder": "",
                    "account_type_key": "",
                    "bind": ""
                  }
                ]
              }
            ]
          }
        ],
        "context": "create"
      }
    ],
    "list_actions": [
      {
        "action": "VERIFY",
        "label": "验证",
        "variant": "outline",
        "mode": "sync",
        "params": {},
