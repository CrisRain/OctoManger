{
  "key": "github",
  "name": "GitHub",
  "category": "generic",
  "schema": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "title": "GitHub 用户名"
      },
      "token": {
        "type": "string",
        "title": "Access Token"
      },
      "api_base_url": {
        "type": "string",
        "title": "API Base URL",
        "default": "https://api.github.com"
      },
      "user_agent": {
        "type": "string",
        "title": "User-Agent"
      },
      "timeout_seconds": {
        "type": "integer",
        "title": "超时秒数",
        "default": 30,
        "minimum": 5,
        "maximum": 120
      },
      "default_owner": {
        "type": "string",
        "title": "默认 Owner"
      }
    },
    "required": [
      "username",
      "token"
    ]
  },
  "capabilities": {
    "actions": [
      {
        "key": "VERIFY",
        "description": "验证 Token 是否可用，检测账号活性"
      },
      {
        "key": "HEALTH_CHECK",
        "description": "VERIFY 的别名，检测账号活性"
      },
      {
        "key": "GET_PROFILE",
        "description": "获取当前认证用户资料"
      },
      {
        "key": "LIST_REPOSITORIES",
        "description": "列出当前账号的仓库",
        "params": [
          {
            "name": "organization",
            "type": "string",
            "required": false,
            "description": "组织名（留空则列个人仓库）"
          },
          {
            "name": "visibility",
            "type": "string",
            "required": false,
            "choices": [
              "all",
              "public",
              "private"
            ],
            "description": "仓库可见性（默认 all）"
          },
          {
            "name": "per_page",
            "type": "string",
            "required": false,
            "description": "每页数量（1-100，默认 30）"
          },
          {
            "name": "page",
            "type": "string",
            "required": false,
            "description": "页码（默认 1）"
          }
        ]
      },
      {
        "key": "GET_REPOSITORY",
        "description": "获取单个仓库详情",
        "params": [
          {
            "name": "repo",
            "type": "string",
            "required": true,
            "description": "仓库名"
          },
          {
            "name": "owner",
            "type": "string",
            "required": false,
            "description": "Owner（留空则用 default_owner 或 identifier）"
          }
        ]
      },
      {
        "key": "CREATE_REPOSITORY",
        "description": "创建仓库",
        "params": [
          {
            "name": "name",
            "type": "string",
            "required": true,
            "description": "仓库名"
          },
          {
            "name": "description",
            "type": "string",
            "required": false,
            "description": "仓库描述"
          },
          {
            "name": "private",
            "type": "string",
            "required": false,
            "choices": [
              "true",
              "false"
            ],
            "description": "是否私有（默认 false）"
          },
          {
            "name": "auto_init",
            "type": "string",
            "required": false,
            "choices": [
              "true",
              "false"
            ],
            "description": "是否自动初始化（默认 false）"
          },
          {
            "name": "organization",
            "type": "string",
            "required": false,
            "description": "在指定组织下创建（留空则在个人账号下）"
          }
        ]
      },
      {
        "key": "CREATE_ISSUE",
        "description": "创建 Issue",
        "params": [
          {
            "name": "repo",
            "type": "string",
            "required": true,
            "description": "仓库名"
          },
          {
            "name": "title",
            "type": "string",
            "required": true,
            "description": "Issue 标题"
          },
          {
            "name": "body",
            "type": "string",
            "required": false,
            "description": "Issue 内容"
          },
          {
            "name": "owner",
            "type": "string",
            "required": false,
            "description": "Owner（留空则用 default_owner）"
          }
        ]
      },
      {
        "key": "REGISTER",
        "description": "自动注册 GitHub 账号（通过 2captcha 解验证码，轮询邮箱获取验证码）",
        "params": [
          {
            "name": "username",
            "type": "string",
            "required": true,
            "description": "目标 GitHub 用户名"
          },
          {
            "name": "password",
            "type": "string",
            "required": true,
            "description": "账号密码"
          },
          {
            "name": "email",
            "type": "string",
            "required": true,
            "description": "注册邮箱"
          },
          {
            "name": "email_account_id",
            "type": "string",
            "required": true,
            "description": "OctoManger 邮箱账号 ID"
          },
          {
            "name": "twocaptcha_api_key",
            "type": "string",
            "required": false,
            "description": "2captcha Key（留空则读取模块设置或 spec）"
          },
          {
            "name": "mode",
            "type": "string",
            "required": false,
            "choices": [
              "api",
              "browser"
            ],
            "description": "注册模式：api 或 browser（默认 api）"
          },
          {
            "name": "email_api_url",
            "type": "string",
            "required": false,
            "description": "OctoManger 后端地址（留空则从 context 自动读取）"
          },
          {
            "name": "email_api_key",
            "type": "string",
            "required": false,
            "description": "OctoManger API Key（留空则从 context 自动读取）"
          },
          {
            "name": "proxy",
            "type": "string",
            "required": false,
            "description": "HTTP 代理（留空则读取模块设置或 spec）"
          },
          {
            "name": "wait_seconds",
            "type": "string",
            "required": false,
            "description": "等待验证码邮件最长秒数（默认 120）"
          },
          {
            "name": "poll_interval",
            "type": "string",
            "required": false,
            "description": "轮询间隔秒数（默认 8）"
          },
          {
            "name": "arkose_public_key",
            "type": "string",
            "required": false,
            "description": "手动指定 Arkose 公钥 UUID"
          },
          {
            "name": "arkose_subdomain",
            "type": "string",
            "required": false,
            "description": "手动指定 Arkose API JS 子域"
          }
        ]
      },
      {
        "key": "WATCH",
        "description": "保活守护进程（心跳模式）",
        "params": [
          {
            "name": "interval_seconds",
            "type": "string",
            "required": false,
            "description": "心跳间隔秒数（默认 60）"
          },
          {
            "name": "stop_after_seconds",
            "type": "string",
            "required": false,
            "description": "运行多少秒后自动停止（0 表示不停止）"
          },
          {
            "name": "emit_heartbeat",
            "type": "string",
            "required": false,
            "choices": [
              "true",
              "false"
            ],
            "description": "是否输出心跳事件（默认 false）"
          }
        ]
      }
    ]
  },
  "settings": [
    {
      "key": "twocaptcha_api_key",
      "label": "2captcha API Key",
      "type": "string",
      "secret": true,
      "description": "用于 REGISTER 时自动解 Arkose Labs 验证码",
      "required": false
    },
    {
      "key": "proxy",
      "label": "HTTP 代理",
      "type": "string",
      "secret": false,
      "description": "注册时使用的代理，格式 http://host:port",
      "required": false
    }
  ],
  "ui": {
    "tabs": [
      {
        "key": "account",
        "label": "账号",
        "sections": [
          {
            "title": "账号操作",
            "fields": [],
            "buttons": [
              {
                "action": "VERIFY",
                "label": "验证活性",
                "variant": "outline",
                "mode": "sync",
                "params": {},
                "form": []
              },
              {
                "action": "GET_PROFILE",
                "label": "获取资料",
                "variant": "outline",
                "mode": "sync",
                "params": {},
                "form": []
              }
            ]
          }
        ],
        "context": ""
      },
      {
        "key": "repos",
        "label": "仓库",
        "sections": [
          {
            "title": "仓库管理",
            "fields": [],
            "buttons": [
              {
                "action": "LIST_REPOSITORIES",
                "label": "列出仓库",
                "variant": "outline",
                "mode": "sync",
                "params": {},
                "form": []
              },
              {
                "action": "CREATE_REPOSITORY",
                "label": "创建仓库",
                "variant": "outline",
                "mode": "sync",
                "params": {},
                "form": [
                  {
                    "name": "name",
                    "type": "string",
                    "required": true,
                    "description": "仓库名"
                  },
                  {
                    "name": "description",
                    "type": "string",
                    "required": false,
                    "description": "仓库描述"
                  },
                  {
                    "name": "private",
                    "type": "string",
                    "required": false,
                    "choices": [
                      "true",
                      "false"
                    ],
                    "description": "是否私有（默认 false）"
                  },
                  {
                    "name": "auto_init",
                    "type": "string",
                    "required": false,
                    "choices": [
                      "true",
                      "false"
                    ],
                    "description": "是否自动初始化（默认 false）"
                  }
                ]
              }
            ]
          }
        ],
        "context": ""
      },
      {
        "key": "register",
        "label": "注册",
        "sections": [
          {
            "title": "自动注册",
            "fields": [],
            "buttons": [
              {
                "action": "REGISTER",
                "label": "注册账号",
                "variant": "outline",
                "mode": "job",
                "params": {},
                "form": [
                  {
                    "name": "username",
                    "type": "string",
                    "required": true,
                    "description": "GitHub 用户名"
                  },
                  {
                    "name": "password",
                    "type": "string",
                    "required": true,
                    "description": "账号密码"
                  },
                  {
                    "name": "email",
                    "type": "string",
                    "required": true,
                    "description": "注册邮箱地址"
                  },
                  {
                    "name": "email_account_id",
                    "type": "string",
                    "required": true,
                    "description": "OctoManger 邮箱账号 ID"
                  },
                  {
                    "name": "twocaptcha_api_key",
                    "type": "string",
                    "required": false,
                    "description": "2captcha Key（留空则读取模块设置）"
                  },
                  {
                    "name": "mode",
                    "type": "string",
                    "required": false,
                    "choices": [
                      "api",
                      "browser"
                    ],
                    "description": "注册模式（默认 api）"
                  },
                  {
                    "name": "proxy",
                    "type": "string",
                    "required": false,
                    "description": "HTTP 代理（留空则读取模块设置）"
                  },
                  {
                    "name": "wait_seconds",
                    "type": "string",
                    "required": false,
                    "description": "等待验证码邮件最长秒数（默认 120）"
                  }
                ]
              }
            ]
          }
        ],
        "context": "create"
      }
    ],
    "list_actions": [
      {
        "action": "VERIFY",
        "label": "验证活性",
        "variant": "outline",
        "mode": "sync",
        "params": {},
        "form": []
      }
    ]
  },
  "script_config": {}
}
