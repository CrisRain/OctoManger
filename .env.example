APP_ENV=development

# HTTP API
API_ADDR=:8080
API_READ_TIMEOUT=15s
API_IDLE_TIMEOUT=60s

# Auth (required in production)
ADMIN_KEY=change-me
# Optional key rotation / multi-key mode (comma-separated), takes precedence over ADMIN_KEY
ADMIN_KEYS=
# Optional dedicated token for plugin-internal API (defaults to first admin key)
PLUGIN_INTERNAL_API_TOKEN=

# Database (required)
DATABASE_DSN=postgres://octo:octo@127.0.0.1:5432/octomanger?sslmode=disable
MIGRATION_MODE=versioned

# Cache
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# Worker
WORKER_ID=worker-local
PLUGINS_TIMEOUT_ACCOUNT=60s
PLUGINS_TIMEOUT_JOB=10m
PLUGINS_TIMEOUT_AGENT=0s

# Plugin runtime
PLUGINS_DIR=plugins/modules
PLUGIN_SDK_DIR=plugins/sdk/python
PYTHON_BIN=python3
PLUGIN_GRPC_OCTO_DEMO_ADDR=127.0.0.1:50051
PLUGIN_GRPC_ALLOW_INSECURE_REMOTE=false
PLUGIN_GRPC_INSECURE_SKIP_VERIFY=false

# API CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Admin-Key,X-Api-Key,X-Trigger-Token
CORS_MAX_AGE=10m
