.gocache/

# ============================================================
# Python
# ============================================================

# 字节码缓存
__pycache__/
*.py[cod]
*.pyo
*$py.class

# 虚拟环境（各模块独立 .venv，不提交）
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.python-version

# 打包 / 分发产物
*.egg-info/
*.egg
dist/
build/
pip-log.txt
pip-wheel-metadata/

