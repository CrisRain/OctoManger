*.tsbuildinfo

# 自动生成的类型声明文件
apps/web/*.d.ts
apps/web/src/*.d.ts

# 本地前端缓存 / 临时脚本
apps/web/.vite/
apps/web/.cache/
apps/web/fix-*.js
apps/web/fix-*.mjs
apps/web/unify*.js
apps/web/unify*.mjs
apps/web/replace.js
apps/web/test-*.js
apps/web/test-*.cjs
apps/web/test-*.mjs
apps/web/test-*.ts
apps/web/test-*.tsx

